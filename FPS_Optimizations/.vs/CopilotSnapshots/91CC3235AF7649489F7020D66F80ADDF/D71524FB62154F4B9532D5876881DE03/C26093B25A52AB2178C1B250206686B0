// DefaultMoveEntityThrottlePatch.cs
//
// Distance-based throttle for EntityAlive.DefaultMoveEntity — the physics
// step (CharacterController.Move + entityCollision) inside MoveEntityHeaded.
//
// Deep instrumentation shows DefaultMoveEntity accounts for 30-40% of
// MoveEntityHeaded cost, and entityCollision inside it scales O(n²).
//
// Strategy: for non-combat entities at medium range (20m+), skip the full
// physics step on some frames and apply only lightweight gravity/friction
// to the motion vector.  CharacterController.Move still runs on the next
// full-physics frame, catching up smoothly.
//
// CONSERVATIVE by design — combat entities, close-range, and low zombie
// counts always run the full physics step.

using System.Collections.Generic;
using System.Runtime.CompilerServices;
using HarmonyLib;
using UnityEngine;

[HarmonyPatch(typeof(EntityAlive), "DefaultMoveEntity")]
public static class DefaultMoveEntityThrottlePatch
{
    private static readonly Dictionary<int, int> s_lastFullFrame = new Dictionary<int, int>(256);

    private const float THROTTLE_DIST_SQ = 400f;   // 20 m — never throttle closer
    private const float FAR_DIST_SQ = 2500f;        // 50 m — more aggressive

    public static bool Prefix(EntityAlive __instance)
    {
        if (!OptimizationConfig.Current.EnableDefaultMoveThrottle) return true;
        if (__instance == null) return true;
        if (__instance is EntityPlayer) return true;

        FrameCache.EnsureUpdated();
        if (FrameCache.ShouldBypassThrottling) return true;

        try
        {
            if (__instance.IsSleeping) return true;

            int zombieCount = FrameCache.ZombieCount;
            if (zombieCount < AdaptiveThresholds.EmergencyZombieThreshold) return true;

            bool inCombat = __instance.GetAttackTarget() != null
                         || __instance.GetRevengeTarget() != null
                         || __instance.hasBeenAttackedTime > 0
                         || __instance.isAlert
                         || __instance.HasInvestigatePosition;
            if (inCombat) return true;

            float distSq = (__instance.position - FrameCache.PlayerPosition).sqrMagnitude;
            if (distSq < THROTTLE_DIST_SQ) return true;

            // Determine skip interval based on distance and zombie pressure
            bool criticalMode = zombieCount >= AdaptiveThresholds.CriticalZombieThreshold;
            bool siegeMode = zombieCount >= 100;

            int interval;
            if (distSq >= FAR_DIST_SQ)
                interval = siegeMode ? 4 : (criticalMode ? 3 : 2);
            else
                interval = criticalMode ? 2 : (siegeMode ? 3 : 2);

            int entityId = __instance.entityId;
            int currentFrame = Time.frameCount;

            if (!s_lastFullFrame.TryGetValue(entityId, out int lastFrame))
            {
                s_lastFullFrame[entityId] = currentFrame;
                return true;
            }

            if (currentFrame - lastFrame >= interval)
            {
                s_lastFullFrame[entityId] = currentFrame;
                return true;
            }

            // Throttled frame: apply gravity/friction only — no CharacterController.Move
            ApplyLitePhysics(__instance);
            ProfilerCounterBridge.Increment("DefaultMoveEntity.Throttled");
            return false;
        }
        catch
        {
            return true;
        }
    }

    /// <summary>
    /// Lightweight physics: apply gravity and friction to the motion vector
    /// without calling CharacterController.Move or entityCollision.
    /// The next full-physics frame picks up where we left off.
    /// </summary>
    [MethodImpl(MethodImplOptions.AggressiveInlining)]
    private static void ApplyLitePhysics(EntityAlive entity)
    {
        try
        {
            float gravity = entity.world.Gravity;

            if (entity.isSwimming)
            {
                entity.motion.x *= 0.91f;
                entity.motion.z *= 0.91f;
                entity.motion.y -= gravity * 0.025f;
                entity.motion.y *= 0.91f;
            }
            else if (entity.onGround)
            {
                // Ground friction — same as vanilla's 0.546f
                entity.motion.x *= 0.546f;
                entity.motion.z *= 0.546f;
                // Keep Y at zero so gravity doesn't accumulate
                entity.motion.y = 0f;
            }
            else if (!entity.bInElevator)
            {
                // Airborne: apply gravity
                entity.motion.x *= 0.91f;
                entity.motion.z *= 0.91f;
                entity.motion.y -= gravity;
                entity.motion.y *= 0.98f;
            }
        }
        catch { }
    }

    public static void OnEntityRemoved(int entityId) => s_lastFullFrame.Remove(entityId);
    public static void ClearCaches() => s_lastFullFrame.Clear();
}
