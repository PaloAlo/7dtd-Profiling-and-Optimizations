// XUiAlwaysUpdatePatch.cs
//
// Prevents XUiC_Toolbelt and XUiC_Radial from forcing a full XUi
// rebuild every single frame by returning false from AlwaysUpdate().
//
// XUiUpdater calls AlwaysUpdate() on each controller to decide whether
// to mark it dirty unconditionally.  Vanilla returns true for the hotbar
// and radial menu, meaning they get a full DOM rebuild + layout recalc
// every frame regardless of whether any data changed.
//
// Returning false means these controllers only rebuild when they have
// genuine dirty state (item changes, etc.) — the correct behaviour.
// The XUiThrottlePatch already limits how often XUiUpdater runs;
// this patch reduces the work done *within* each update that does fire.
//
// Adapted from Redbeardt's Afterlife mod (XUiOpts.cs).

using HarmonyLib;

[HarmonyPatch(typeof(XUiC_Toolbelt), "AlwaysUpdate")]
public static class XUiToolbeltAlwaysUpdatePatch
{
    [HarmonyPrefix]
    public static bool Prefix(ref bool __result)
    {
        if (!OptimizationConfig.Current.EnableXUiThrottle) return true;
        __result = false;
        return false;
    }
}

// XUiC_Radial.AlwaysUpdate is intentionally NOT patched.
// The radial controller manages the player's interaction context — what
// pressing 'E' does near entities (traders, loot, vehicles, etc.).
// Blocking its AlwaysUpdate prevents it from detecting nearby interactables,
// breaking the trader 'E' key and any other context-sensitive interactions.
