// ProfilerRunner.cs

using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Diagnostics;
using UnityEngine;
using HarmonyLib;

/// <summary>
/// Lightweight per-frame profiler runner with automatic high-load capture.
/// 
/// KEY FEATURES:
/// - Periodic CSV summary rows
/// - Automatic detailed captures during FPS drops
/// - Deep sub-method instrumentation for root cause analysis
/// - Baseline tracking to detect "never recovers" pattern
/// </summary>
public class ProfilerRunner : MonoBehaviour
{
    public static ProfilerRunner Instance { get; private set; }

    // Interval in seconds between CSV dumps
    public float DumpIntervalSeconds = 30f;

    // Thresholds (adjustable)
    public float SpikeThresholdMs = 50f;
    public float PerMethodThresholdMs = 10f;
    public float SingleFrameThresholdMs = 30f;
    public int TopMethodsCount = 5;

    // === HIGH-LOAD AUTOMATIC CAPTURE SETTINGS ===
    public float LowFpsThreshold = 30f;
    public int MinZombiesForCapture = 50;
    public float CaptureDebounceSeconds = 30f;  // Increased to avoid repeated captures
    public int MaxHighLoadCaptures = 5;

    // === RECOVERY TRACKING ===
    public float RecoveryCheckIntervalSeconds = 60f;
    public float RecoveryFpsThreshold = 0.8f;  // If FPS stays below 80% of baseline, flag as "not recovered"

    private float _accum = 0f;
    private float _recoveryAccum = 0f;
    private string _outPath;
    private bool _headerWritten;
    private bool _sessionSaved;

    // High-load capture tracking
    private float _lastHighLoadCaptureTime = -999f;
    private int _highLoadCaptureCount = 0;
    private float _baselineFps = 60f;
    private float _peakFps = 0f;
    private bool _baselineEstablished = false;
    private Queue<float> _fpsHistory = new Queue<float>();
    private const int FpsHistorySize = 60;

    // Recovery analysis
    private int _peakZombieCount = 0;
    private float _postPeakFps = 0f;
    private bool _wasInHighLoad = false;

    private IDictionary<string, long> _lastSnapshotTicks = new Dictionary<string, long>(StringComparer.Ordinal);
    private bool _dynamicPatchesApplied = false;
    private bool _deepPatchesApplied = false;

    public static void Init(Mod modInstance)
    {
        try
        {
            if (Instance != null) return;

            // Ensure ProfilingUtils knows the mod path so ResolveOutputPath writes into the mod folder
            try { ProfilingUtils.ModInstance = modInstance; } catch { /* defensive */ }

            var go = new GameObject("ProfilerRunner");
            UnityEngine.Object.DontDestroyOnLoad(go);
            Instance = go.AddComponent<ProfilerRunner>();

            Instance._outPath = ProfilingUtils.ResolveOutputPath("7dtd_profile.csv");
            Instance._headerWritten = File.Exists(Instance._outPath);
            LogUtil.Info($"ProfilerRunner initialized. DumpPath={Instance._outPath}");
        }
        catch (Exception ex)
        {
            Log.Warning($"[7dtd_Profiler] ProfilerRunner.Init failed: {ex.Message}");
        }
    }

    private void Update()
    {
        // Apply base dynamic patches
        if (!_dynamicPatchesApplied)
        {
            try
            {
                var harmony = new Harmony(GetType().ToString());
                ProfilingUtils.ApplyDynamicPatches(harmony);
                _dynamicPatchesApplied = true;
                LogUtil.Debug("ProfilerRunner: dynamic profiling patches applied.");
            }
            catch (Exception ex)
            {
                LogUtil.Warn($"ProfilerRunner: ApplyDynamicPatches failed: {ex.Message}");
                _dynamicPatchesApplied = true;
            }
        }

        // Apply deep instrumentation patches (deferred to ensure types are loaded)
        if (_dynamicPatchesApplied && !_deepPatchesApplied && Time.frameCount > 100)
        {
            try
            {
                var harmony = new Harmony(GetType().ToString() + ".Deep");
                DeepEntityInstrumentation.Apply(harmony);
                _deepPatchesApplied = true;
            }
            catch (Exception ex)
            {
                LogUtil.Warn($"ProfilerRunner: DeepEntityInstrumentation failed: {ex.Message}");
                _deepPatchesApplied = true;
            }
        }

        TrackFps();
        CheckHighLoadCapture();
        CheckRecoveryPattern();

        try { CheckPerFrameSpike(); }
        catch (Exception ex) { LogUtil.Warn($"ProfilerRunner per-frame check error: {ex.Message}"); }

        _accum += Time.unscaledDeltaTime;
        if (_accum >= DumpIntervalSeconds)
        {
            try { DumpRow(); }
            catch (Exception ex) { LogUtil.Warn($"ProfilerRunner DumpRow error: {ex.Message}"); }
            _accum = 0f;
            ProfilingUtils.Clear();
            ProfilingUtils.PerFrameCounters.ResetAll();
            _lastSnapshotTicks.Clear();
        }

        try
        {
            if (ProfilerConfig.Current.EnablePathWorker)
                PathRequestQueue.PumpMainThread();
        }
        catch (Exception ex)
        {
            LogUtil.Warn($"PathRequestQueue.PumpMainThread failed: {ex.Message}");
        }
    }

    private void TrackFps()
    {
        if (Time.unscaledDeltaTime <= 0) return;

        var currentFps = 1f / Time.unscaledDeltaTime;
        _fpsHistory.Enqueue(currentFps);

        while (_fpsHistory.Count > FpsHistorySize)
            _fpsHistory.Dequeue();

        if (currentFps > _peakFps)
            _peakFps = currentFps;

        var zombieCount = FindZombieCount();
        if (zombieCount > _peakZombieCount)
            _peakZombieCount = zombieCount;

        // Establish baseline during good conditions
        if (!_baselineEstablished && zombieCount < 10 && _fpsHistory.Count >= FpsHistorySize)
        {
            var avgFps = _fpsHistory.Average();
            if (avgFps > 50f)
            {
                _baselineFps = avgFps;
                _baselineEstablished = true;
                LogUtil.Info($"Baseline FPS: {_baselineFps:F1}");
            }
        }
    }

    /// <summary>
    /// Track the "never recovers to baseline" pattern you observed.
    /// </summary>
    private void CheckRecoveryPattern()
    {
        _recoveryAccum += Time.unscaledDeltaTime;
        if (_recoveryAccum < RecoveryCheckIntervalSeconds) return;
        _recoveryAccum = 0f;

        if (!_baselineEstablished) return;

        var zombieCount = FindZombieCount();
        var currentFps = _fpsHistory.Count > 0 ? _fpsHistory.Average() : 60f;
        var isCurrentlyHighLoad = zombieCount >= MinZombiesForCapture || currentFps < LowFpsThreshold;

        // If we were in high load and now zombie count is low, check if FPS recovered
        if (_wasInHighLoad && !isCurrentlyHighLoad && zombieCount < 20)
        {
            _postPeakFps = currentFps;
            var recoveryRatio = currentFps / _baselineFps;

            if (recoveryRatio < RecoveryFpsThreshold)
            {
                LogUtil.Warn($"RECOVERY ISSUE DETECTED: Post-peak FPS={currentFps:F1} vs Baseline={_baselineFps:F1} (only {recoveryRatio * 100:F0}% recovered). Peak zombies was {_peakZombieCount}.");

                // Capture a "recovery failure" dump to analyze lingering costs
                CaptureHighLoadDump(zombieCount, currentFps, "RECOVERY_FAIL");
            }
            else
            {
                LogUtil.Debug($"Recovery OK: {recoveryRatio * 100:F0}% of baseline FPS restored.");
            }

            _wasInHighLoad = false;
            _peakZombieCount = 0;
        }

        if (isCurrentlyHighLoad)
            _wasInHighLoad = true;
    }

    private void CheckHighLoadCapture()
    {
        if (_highLoadCaptureCount >= MaxHighLoadCaptures) return;

        var timeSinceLastCapture = Time.realtimeSinceStartup - _lastHighLoadCaptureTime;
        if (timeSinceLastCapture < CaptureDebounceSeconds) return;

        var zombieCount = FindZombieCount();
        if (zombieCount < MinZombiesForCapture) return;

        var currentFps = _fpsHistory.Count > 0 ? _fpsHistory.Average() : 60f;
        var fpsDroppedSignificantly = _baselineEstablished && currentFps < _baselineFps * 0.5f;
        var fpsBelowThreshold = currentFps < LowFpsThreshold;

        if (fpsBelowThreshold || fpsDroppedSignificantly)
        {
            CaptureHighLoadDump(zombieCount, currentFps, fpsBelowThreshold ? "LOW_FPS" : "FPS_DROP");
        }
    }

    private void CaptureHighLoadDump(int zombieCount, float currentFps, string triggerReason)
    {
        try
        {
            var entries = ProfilingUtils.SnapshotEntries();
            var counters = ProfilingUtils.PerFrameCounters.SnapshotAndReset();
            var timestamp = DateTime.UtcNow.ToString("yyyyMMdd_HHmmss");
            var fileName = $"7dtd_HIGHLOAD_{triggerReason}_z{zombieCount}_fps{currentFps:F0}_{timestamp}.csv";
            var path = ProfilingUtils.ResolveOutputPath(fileName);

            var sb = new System.Text.StringBuilder();
            sb.AppendLine($"# HIGH-LOAD CAPTURE: {triggerReason}");
            sb.AppendLine($"# Timestamp: {DateTime.UtcNow:o}");
            sb.AppendLine($"# Frame: {Time.frameCount}");
            sb.AppendLine($"# ZombieCount: {zombieCount}");
            sb.AppendLine($"# CurrentFPS: {currentFps:F2}");
            sb.AppendLine($"# BaselineFPS: {_baselineFps:F2}");
            sb.AppendLine($"# PeakFPS: {_peakFps:F2}");
            sb.AppendLine($"# FPSDrop%: {(1 - currentFps / _baselineFps) * 100:F1}%");
            sb.AppendLine($"# PeakZombies: {_peakZombieCount}");
            sb.AppendLine($"# CaptureNumber: {_highLoadCaptureCount + 1}/{MaxHighLoadCaptures}");
            sb.AppendLine($"# GC_MB: {GC.GetTotalMemory(false) / 1048576.0:F1}");
            sb.AppendLine();

            // === TIMING DATA ===
            sb.AppendLine("=== TIMING DATA (sorted by TotalMs) ===");
            sb.AppendLine("Tag,TotalMs,Calls,AvgMs,PercentOfTotal,Category");

            var totalMs = entries.Values.Sum(e => e.TotalMs);
            foreach (var kv in entries.OrderByDescending(e => e.Value.TotalMs))
            {
                var pct = totalMs > 0 ? (kv.Value.TotalMs / totalMs * 100) : 0;
                var category = CategorizeTag(kv.Key);
                sb.AppendLine($"{kv.Key},{kv.Value.TotalMs:F4},{kv.Value.Calls},{kv.Value.AvgMs:F6},{pct:F2}%,{category}");
            }

            // === CALL COUNTS ===
            sb.AppendLine();
            sb.AppendLine("=== CALL COUNTS ===");
            sb.AppendLine("Counter,Value");
            foreach (var kv in counters.OrderByDescending(c => c.Value))
            {
                sb.AppendLine($"{kv.Key},{kv.Value}");
            }

            // === PATH CACHE STATS ===
            try
            {
                sb.AppendLine();
                sb.AppendLine("=== PATH CACHE STATS ===");
                // include current cache size
                int cacheCount = 0;
                try { cacheCount = PathCache.Count; } catch { cacheCount = -1; }
                sb.AppendLine($"PathCache.Count,{cacheCount}");

                // include counters if present
                counters.TryGetValue("PathCache.Hit", out var pathCacheHits);
                counters.TryGetValue("PathCache.Miss", out var pathCacheMisses);
                counters.TryGetValue("PathCache.Store", out var pathCacheStores);

                sb.AppendLine($"PathCache.Hit,{pathCacheHits}");
                sb.AppendLine($"PathCache.Miss,{pathCacheMisses}");
                sb.AppendLine($"PathCache.Store,{pathCacheStores}");
            }
            catch (Exception ex)
            {
                // don't fail the dump if path cache introspection throws
                sb.AppendLine($"# Path cache stats unavailable: {ex.Message}");
            }

            // === COST PER ZOMBIE ANALYSIS ===
            sb.AppendLine();
            sb.AppendLine("=== COST PER ZOMBIE ANALYSIS ===");
            if (zombieCount > 0)
            {
                sb.AppendLine($"TotalMs per zombie: {totalMs / zombieCount:F4}");
                foreach (var kv in entries.Where(e => e.Value.TotalMs > 1).OrderByDescending(e => e.Value.TotalMs).Take(10))
                {
                    sb.AppendLine($"{kv.Key}: {kv.Value.TotalMs / zombieCount:F4} ms/zombie");
                }
            }

            File.WriteAllText(path, sb.ToString());

            _lastHighLoadCaptureTime = Time.realtimeSinceStartup;
            _highLoadCaptureCount++;

            LogUtil.Info($"HIGH-LOAD #{_highLoadCaptureCount}: {triggerReason} | Z={zombieCount} | FPS={currentFps:F1} | File={fileName}");
        }
        catch (Exception ex)
        {
            LogUtil.Warn($"ProfilerRunner high-load capture failed: {ex.Message}");
        }
    }

    private string CategorizeTag(string tag)
    {
        var t = tag.ToLowerInvariant();
        if (t.Contains("playerlocal")) return "PLAYER";
        if (t.Contains("entityalive") && !t.Contains("player")) return "AI_ENTITY";
        if (t.Contains("eai") || t.Contains("task")) return "AI_TASK";
        if (t.Contains("path") || t.Contains("navigate")) return "PATHFINDING";
        if (t.Contains("see") || t.Contains("sense") || t.Contains("target")) return "SENSING";
        if (t.Contains("buff") || t.Contains("status")) return "BUFFS";
        if (t.Contains("move") || t.Contains("physics")) return "MOVEMENT";
        if (t.Contains("gui") || t.Contains("window")) return "UI";
        return "OTHER";
    }

    private void CheckPerFrameSpike()
    {
        var ticks = ProfilingUtils.SnapshotTicks();
        if (ticks == null || ticks.Count == 0)
        {
            _lastSnapshotTicks = ticks ?? new Dictionary<string, long>(StringComparer.Ordinal);
            return;
        }

        foreach (var kv in ticks)
        {
            var tag = kv.Key;
            var totalTicks = kv.Value;
            _lastSnapshotTicks.TryGetValue(tag, out var prevTicks);
            var deltaTicks = totalTicks - prevTicks;
            if (deltaTicks <= 0) continue;
            var deltaMs = deltaTicks * 1000.0 / Stopwatch.Frequency;
            if (deltaMs >= SingleFrameThresholdMs)
            {
                try
                {
                    var entries = ProfilingUtils.SnapshotEntries();
                    if (!_sessionSaved)
                    {
                        SaveDetailedSessionDump(entries);
                        _sessionSaved = true;
                        LogUtil.Info($"ProfilerRunner: per-frame spike detected (tag={tag}, ms={deltaMs:F3})");
                    }
                }
                catch (Exception ex)
                {
                    LogUtil.Warn($"ProfilerRunner per-frame dump failed: {ex.Message}");
                }
                break;
            }
        }

        _lastSnapshotTicks = ticks;
    }

    private void DumpRow()
    {
        var entries = ProfilingUtils.SnapshotEntries();
        var counters = ProfilingUtils.PerFrameCounters.SnapshotAndReset();

        double aiMs = 0, pathMs = 0, sensesMs = 0, physicsMs = 0, otherMs = 0;
        foreach (var kv in entries)
        {
            var tag = kv.Key;
            var entryMs = kv.Value.TotalMs;
            var t = tag.ToLowerInvariant();
            if (t.Contains("entityalive") || t.Contains(".updateai") || t.Contains("updateai") || t.Contains("eai")) aiMs += entryMs;
            else if (t.Contains("path") || t.Contains("findpath") || t.Contains("pathfinder") || t.Contains("navigate")) pathMs += entryMs;
            else if (t.Contains("sense") || t.Contains("los") || t.Contains("lineof") || t.Contains("cansee")) sensesMs += entryMs;
            else if (t.Contains("physics") || t.Contains("raycast") || t.Contains("rigidbody")) physicsMs += entryMs;
            else otherMs += entryMs;
        }

        var zombieCount = FindZombieCount();
        var totalMs = aiMs + pathMs + sensesMs + physicsMs + otherMs;
        counters.TryGetValue("raycasts", out var raycasts);
        counters.TryGetValue("rigidbodies", out var rigidbodies);
        counters.TryGetValue("pathRequests", out var pathRequests);
        counters.TryGetValue("navigatorSetPathCalls", out var navigatorSetPathCalls);
        counters.TryGetValue("pathCalculations", out var pathCalculations);
        counters.TryGetValue("Entity.Update.calls", out var entityUpdateCalls);
        counters.TryGetValue("EntityAlive.Update.calls", out var entityAliveUpdateCalls);
        var gcKb = GC.GetTotalMemory(false) / 1024;
        var currentFps = _fpsHistory.Count > 0 ? _fpsHistory.Average() : 0f;

        var headerBase = "TimeUtc,Frame,ZombieCount,AI_ms,Path_ms,Sensing_ms,Physics_ms,Other_ms,TotalMs,Raycasts,Rigidbodies,GC_kb,PathRequests,NavigatorSetPathCalls,PathCalculations,EntityUpdateCalls,EntityAliveUpdateCalls,CurrentFPS,BaselineFPS,PeakFPS";

        var top = entries.OrderByDescending(kv => kv.Value.TotalMs).Take(TopMethodsCount).ToList();
        var topHeaderParts = new List<string>();
        for (int i = 0; i < TopMethodsCount; i++)
        {
            topHeaderParts.Add($"Top{i + 1}_Tag");
            topHeaderParts.Add($"Top{i + 1}_ms");
        }
        var header = headerBase + (topHeaderParts.Count > 0 ? "," + string.Join(",", topHeaderParts) : "");

        var baseRowParts = new List<string>
        {
            DateTime.UtcNow.ToString("o"),
            Time.frameCount.ToString(),
            zombieCount.ToString(),
            aiMs.ToString("F4"),
            pathMs.ToString("F4"),
            sensesMs.ToString("F4"),
            physicsMs.ToString("F4"),
            otherMs.ToString("F4"),
            totalMs.ToString("F4"),
            raycasts.ToString(),
            rigidbodies.ToString(),
            gcKb.ToString(),
            pathRequests.ToString(),
            navigatorSetPathCalls.ToString(),
            pathCalculations.ToString(),
            entityUpdateCalls.ToString(),
            entityAliveUpdateCalls.ToString(),
            currentFps.ToString("F2"),
            _baselineFps.ToString("F2"),
            _peakFps.ToString("F2")
        };

        for (int i = 0; i < TopMethodsCount; i++)
        {
            if (i < top.Count)
            {
                baseRowParts.Add(EscapeForCsv(top[i].Key));
                baseRowParts.Add(top[i].Value.TotalMs.ToString("F4"));
            }
            else
            {
                baseRowParts.Add("");
                baseRowParts.Add("");
            }
        }

        var row = string.Join(",", baseRowParts);

        try
        {
            var dir = Path.GetDirectoryName(_outPath);
            if (!string.IsNullOrEmpty(dir) && !Directory.Exists(dir)) Directory.CreateDirectory(dir);
            if (!_headerWritten)
            {
                File.AppendAllText(_outPath, header + Environment.NewLine);
                _headerWritten = true;
            }
            File.AppendAllText(_outPath, row + Environment.NewLine);
        }
        catch (Exception ex)
        {
            LogUtil.Warn($"ProfilerRunner failed to write CSV: {ex.Message}");
        }

        try
        {
            if (!_sessionSaved)
            {
                var anyHot = entries.Any(kv => kv.Value.TotalMs >= PerMethodThresholdMs);
                if (totalMs >= SpikeThresholdMs || anyHot)
                {
                    SaveDetailedSessionDump(entries);
                    _sessionSaved = true;
                }
            }
        }
        catch (Exception ex)
        {
            LogUtil.Warn($"ProfilerRunner SaveDetailedSessionDump error: {ex.Message}");
        }
    }

    private void SaveDetailedSessionDump(IDictionary<string, (double TotalMs, long Calls, double AvgMs)> entriesSnapshot)
    {
        try
        {
            var fileName = $"7dtd_profile_details_{DateTime.UtcNow:yyyyMMdd_HHmmss}.csv";
            var path = ProfilingUtils.ResolveOutputPath(fileName);
            ProfilingUtils.SaveCsv(path);
            LogUtil.Info($"ProfilerRunner saved detailed profile dump: {path}");
        }
        catch (Exception ex)
        {
            LogUtil.Warn($"ProfilerRunner failed to save detailed dump: {ex.Message}");
        }
    }

    private static string EscapeForCsv(string s)
    {
        if (string.IsNullOrEmpty(s)) return "";
        if (s.Contains(",") || s.Contains("\"") || s.Contains("\n"))
            return "\"" + s.Replace("\"", "\"\"") + "\"";
        return s;
    }

    private int FindZombieCount()
    {
        try
        {
            var gm = GameManager.Instance;
            if (gm?.World == null) return 0;

            var entities = gm.World.Entities;
            if (entities == null) return 0;

            int count = 0;
            var list = entities.list;
            if (list != null)
            {
                for (int i = 0; i < list.Count; i++)
                {
                    var e = list[i];
                    if (e != null && e.IsAlive() && e is EntityEnemy)
                        count++;
                }
            }
            return count;
        }
        catch { return 0; }
    }
}