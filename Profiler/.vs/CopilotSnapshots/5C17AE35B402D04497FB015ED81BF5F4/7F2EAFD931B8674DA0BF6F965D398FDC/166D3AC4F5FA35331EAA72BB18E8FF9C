// MoveEntityHeadedLODPatch.cs
//
// Aggressive LOD-based throttling for EntityAlive.MoveEntityHeaded
// Now includes emergency throttling when zombie count is high
// FIX: Combat-engaged entities ALWAYS get full movement updates regardless of zombie count.

using System.Collections.Generic;
using System.Runtime.CompilerServices;
using HarmonyLib;
using UnityEngine;

[HarmonyPatch(typeof(EntityAlive), nameof(EntityAlive.MoveEntityHeaded))]
public static class MoveEntityHeadedLODPatch
{
    private static readonly Dictionary<int, int> s_lastUpdateFrame = new Dictionary<int, int>(256);
    private static Vector3 s_cachedPlayerPos;
    private static int s_cachedPlayerFrame = -1;
    private static int s_cachedZombieCount = 0;

    // Emergency throttle thresholds
    private const int EMERGENCY_ZOMBIE_THRESHOLD = 40;
    private const int CRITICAL_ZOMBIE_THRESHOLD = 80;

    public static bool Prefix(EntityAlive __instance, Vector3 _direction, bool _isDirAbsolute)
    {
        if (!ProfilerConfig.Current.EnableMoveLOD) return true;
        if (__instance == null) return true;

        // NEVER throttle players
        if (__instance is EntityPlayer) return true;

        try
        {
            // ALWAYS allow combat-engaged entities full movement
            // This prevents stop-and-go stuttering for active zombies
            if (IsCombatOrStateActive(__instance)) return true;

            int entityId = __instance.entityId;
            int currentFrame = Time.frameCount;

            UpdateCaches(currentFrame);
            float distSq = (__instance.position - s_cachedPlayerPos).sqrMagnitude;

            float tier1Sq = ProfilerConfig.Current.MoveLODTier1DistSq;
            float tier2Sq = ProfilerConfig.Current.MoveLODTier2DistSq;
            float tier3Sq = ProfilerConfig.Current.MoveLODTier3DistSq;

            // Check if we're in emergency mode (many zombies)
            bool emergencyMode = s_cachedZombieCount >= EMERGENCY_ZOMBIE_THRESHOLD;
            bool criticalMode = s_cachedZombieCount >= CRITICAL_ZOMBIE_THRESHOLD;

            // Tier 0 (very close) - ALWAYS run full update (never reduce this threshold)
            if (distSq < tier1Sq)
            {
                return true;
            }

            // Calculate skip interval based on distance AND zombie count
            int skipInterval;
            if (distSq < tier2Sq)
            {
                // 30-50m: moderate throttle only in emergency
                skipInterval = criticalMode ? 3 : (emergencyMode ? 2 : 1);
            }
            else if (distSq < tier3Sq)
            {
                // 50-80m: heavier throttle
                skipInterval = criticalMode ? 5 : (emergencyMode ? 4 : 3);
            }
            else
            {
                // >80m: heaviest throttle
                skipInterval = criticalMode ? 8 : (emergencyMode ? 6 : 5);
            }

            if (skipInterval <= 1) return true;

            // Frame-slicing: distribute updates across frames
            int frameSlot = currentFrame % skipInterval;
            int entitySlot = (entityId & 0x7FFFFFFF) % skipInterval;

            if (frameSlot == entitySlot)
            {
                s_lastUpdateFrame[entityId] = currentFrame;
                return true;
            }

            ProfilingUtils.PerFrameCounters.Increment("MoveEntityHeaded.LODSkipped");
            return false;
        }
        catch
        {
            return true;
        }
    }

    /// <summary>
    /// Returns true if the entity is in any state that requires full movement updates.
    /// </summary>
    [MethodImpl(MethodImplOptions.AggressiveInlining)]
    private static bool IsCombatOrStateActive(EntityAlive entity)
    {
        if (entity.GetAttackTarget() != null) return true;
        if (entity.GetRevengeTarget() != null) return true;
        if (entity.hasBeenAttackedTime > 0) return true;
        if (entity.isAlert) return true;
        if (entity.IsSleeping) return true;
        if (entity.HasInvestigatePosition) return true;
        return false;
    }

    [MethodImpl(MethodImplOptions.AggressiveInlining)]
    private static void UpdateCaches(int frame)
    {
        if (s_cachedPlayerFrame == frame) return;
        s_cachedPlayerFrame = frame;

        var world = GameManager.Instance?.World;
        if (world == null) return;

        var player = world.GetPrimaryPlayer();
        if (player != null)
        {
            s_cachedPlayerPos = player.position;
        }

        // Cache zombie count for emergency throttling
        s_cachedZombieCount = 0;
        var entities = world.Entities.list;
        for (int i = 0; i < entities.Count; i++)
        {
            var entity = entities[i];
            if (entity != null && entity is EntityZombie)
                s_cachedZombieCount++;
        }

        // Report emergency mode status
        if (s_cachedZombieCount >= CRITICAL_ZOMBIE_THRESHOLD)
            ProfilingUtils.PerFrameCounters.SetGauge("MoveLOD.CriticalMode", 1);
        else if (s_cachedZombieCount >= EMERGENCY_ZOMBIE_THRESHOLD)
            ProfilingUtils.PerFrameCounters.SetGauge("MoveLOD.EmergencyMode", 1);
    }

    public static void OnEntityRemoved(int entityId)
    {
        s_lastUpdateFrame.Remove(entityId);
    }
}

// Extension kept for compatibility
public static class EntityAliveExtensions
{
    [MethodImpl(MethodImplOptions.AggressiveInlining)]
    public static bool HasAttackTarget(this EntityAlive entity)
    {
        return entity.GetAttackTarget() != null;
    }
}