// SpeedStrafeThrottlePatch.cs
//
// Throttles EntityAlive.updateSpeedForwardAndStrafe for distant entities.
// MoveEntityHeaded is consistently 33-50% of total CPU time. A large portion
// of that cost is heading/rotation recalculation via updateSpeedForwardAndStrafe.
//
// Even during combat, a zombie at 40m+ doesn't need its heading recalculated
// every single frame — every 2nd or 3rd frame is visually indistinguishable.
// This patch applies a lighter throttle than the full MoveEntityHeaded LOD:
// it lets the main movement call through but skips the expensive sub-calculation.

using System.Collections.Generic;
using System.Runtime.CompilerServices;
using HarmonyLib;
using UnityEngine;

[HarmonyPatch(typeof(EntityAlive), "updateSpeedForwardAndStrafe")]
public static class SpeedStrafeThrottlePatch
{
    private static readonly Dictionary<int, int> s_lastFrame = new Dictionary<int, int>(256);

    private static Vector3 s_cachedPlayerPos;
    private static int s_cachedZombieCount;
    private static int s_cachedFrame = -1;

    private const float ALWAYS_RUN_DIST_SQ = 625f;  // 25m - always run full speed/strafe
    private const float MID_DIST_SQ = 1600f;        // 40m
    private const float FAR_DIST_SQ = 4900f;        // 70m
    private const int EMERGENCY_THRESHOLD = 40;
    private const int CRITICAL_THRESHOLD = 80;

    public static bool Prefix(EntityAlive __instance)
    {
        if (!ProfilerConfig.Current.EnableMoveLOD) return true;
        if (__instance == null) return true;
        if (__instance is EntityPlayer) return true;

        try
        {
            int entityId = __instance.entityId;
            int currentFrame = Time.frameCount;

            UpdateCaches(currentFrame);

            // Below emergency zombie count, don't throttle at all
            if (s_cachedZombieCount < EMERGENCY_THRESHOLD) return true;

            float distSq = (__instance.position - s_cachedPlayerPos).sqrMagnitude;

            // Close entities — always full update
            if (distSq < ALWAYS_RUN_DIST_SQ) return true;

            bool criticalMode = s_cachedZombieCount >= CRITICAL_THRESHOLD;

            int skipInterval;
            if (distSq < MID_DIST_SQ)
            {
                skipInterval = criticalMode ? 3 : 2;
            }
            else if (distSq < FAR_DIST_SQ)
            {
                skipInterval = criticalMode ? 4 : 3;
            }
            else
            {
                skipInterval = criticalMode ? 6 : 4;
            }

            if (skipInterval <= 1) return true;

            int frameSlot = currentFrame % skipInterval;
            int entitySlot = (entityId & 0x7FFFFFFF) % skipInterval;

            if (frameSlot == entitySlot)
            {
                s_lastFrame[entityId] = currentFrame;
                return true;
            }

            ProfilingUtils.PerFrameCounters.Increment("SpeedStrafe.Throttled");
            return false;
        }
        catch
        {
            return true;
        }
    }

    [MethodImpl(MethodImplOptions.AggressiveInlining)]
    private static void UpdateCaches(int frame)
    {
        if (s_cachedFrame == frame) return;
        s_cachedFrame = frame;

        var world = GameManager.Instance?.World;
        if (world == null) return;

        var player = world.GetPrimaryPlayer();
        if (player != null)
            s_cachedPlayerPos = player.position;

        s_cachedZombieCount = 0;
        var entities = world.Entities.list;
        for (int i = 0; i < entities.Count; i++)
        {
            var entity = entities[i];
            if (entity != null && entity is EntityZombie)
                s_cachedZombieCount++;
        }
    }

    public static void OnEntityRemoved(int entityId)
    {
        s_lastFrame.Remove(entityId);
    }
}
