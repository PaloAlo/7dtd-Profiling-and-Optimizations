// SpatialHashGrid.cs
// Lightweight spatial hash for fast neighbor queries in 7DTD
// Uses XZ plane (ignores Y) since most entity queries are horizontal

using System;
using System.Collections.Generic;
using System.Runtime.CompilerServices;
using UnityEngine;

public class SpatialHashGrid<TId> where TId : struct, IEquatable<TId>
{
    private readonly float _cellSize;
    private readonly float _invCellSize;
    private readonly Dictionary<long, List<TId>> _cells = new(256);
    private readonly Dictionary<TId, long> _entityToCell = new(256);

    // Reusable list to avoid allocations
    private readonly List<TId> _queryResults = new(64);

    public SpatialHashGrid(float cellSize = 8f)
    {
        _cellSize = cellSize;
        _invCellSize = 1f / cellSize;
    }

    [MethodImpl(MethodImplOptions.AggressiveInlining)]
    private long CellKey(int x, int z) => ((long)x << 32) | (uint)z;

    [MethodImpl(MethodImplOptions.AggressiveInlining)]
    private (int x, int z) ToCell(float posX, float posZ)
    {
        return ((int)Math.Floor(posX * _invCellSize), (int)Math.Floor(posZ * _invCellSize));
    }

    [MethodImpl(MethodImplOptions.AggressiveInlining)]
    private (int x, int z) ToCell(Vector3 pos) => ToCell(pos.x, pos.z);

    public void Add(TId id, Vector3 position)
    {
        var (x, z) = ToCell(position);
        var key = CellKey(x, z);

        if (!_cells.TryGetValue(key, out var list))
        {
            list = new List<TId>(8);
            _cells[key] = list;
        }
        list.Add(id);
        _entityToCell[id] = key;
    }

    public void Update(TId id, Vector3 newPosition)
    {
        var (x, z) = ToCell(newPosition);
        var newKey = CellKey(x, z);

        if (_entityToCell.TryGetValue(id, out var oldKey))
        {
            if (oldKey == newKey) return; // Same cell

            // Remove from old cell
            if (_cells.TryGetValue(oldKey, out var oldList))
            {
                oldList.Remove(id);
                if (oldList.Count == 0) _cells.Remove(oldKey);
            }
        }

        // Add to new cell
        if (!_cells.TryGetValue(newKey, out var newList))
        {
            newList = new List<TId>(8);
            _cells[newKey] = newList;
        }
        newList.Add(id);
        _entityToCell[id] = newKey;
    }

    public void Remove(TId id)
    {
        if (!_entityToCell.TryGetValue(id, out var key)) return;

        if (_cells.TryGetValue(key, out var list))
        {
            list.Remove(id);
            if (list.Count == 0) _cells.Remove(key);
        }
        _entityToCell.Remove(id);
    }

    public bool Contains(TId id) => _entityToCell.ContainsKey(id);

    /// <summary>
    /// Query all entity IDs within radius of center position.
    /// Returns internal list - iterate immediately, don't store reference.
    /// </summary>
    public List<TId> QueryRadius(Vector3 center, float radius)
    {
        _queryResults.Clear();

        int range = (int)Math.Ceiling(radius * _invCellSize);
        var (cx, cz) = ToCell(center);

        for (int dx = -range; dx <= range; dx++)
        {
            for (int dz = -range; dz <= range; dz++)
            {
                var key = CellKey(cx + dx, cz + dz);
                if (_cells.TryGetValue(key, out var list))
                {
                    for (int i = 0; i < list.Count; i++)
                        _queryResults.Add(list[i]);
                }
            }
        }
        return _queryResults;
    }

    /// <summary>
    /// Query with output list (avoids internal state issues for nested queries)
    /// </summary>
    public void QueryRadius(Vector3 center, float radius, List<TId> outResults)
    {
        outResults.Clear();

        int range = (int)Math.Ceiling(radius * _invCellSize);
        var (cx, cz) = ToCell(center);

        for (int dx = -range; dx <= range; dx++)
        {
            for (int dz = -range; dz <= range; dz++)
            {
                var key = CellKey(cx + dx, cz + dz);
                if (_cells.TryGetValue(key, out var list))
                {
                    for (int i = 0; i < list.Count; i++)
                        outResults.Add(list[i]);
                }
            }
        }
    }

    public void Clear()
    {
        _cells.Clear();
        _entityToCell.Clear();
    }

    public int CellCount => _cells.Count;
    public int EntityCount => _entityToCell.Count;
}