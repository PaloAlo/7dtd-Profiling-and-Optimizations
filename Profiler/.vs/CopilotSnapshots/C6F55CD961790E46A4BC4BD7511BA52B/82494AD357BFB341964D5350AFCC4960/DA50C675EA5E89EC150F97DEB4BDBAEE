// VoxelFastRejectPatches.cs
//
// Voxel-based fast-reject patches for expensive PhysX raycasts/sweeps.
// Inspired by ZehMatt's approach: use cheap voxel grid checks to short-circuit
// PhysX broadphase→narrowphase when blocks are the obstacle.
//
// Safety: every Prefix is wrapped in try/catch and returns true on error
// so vanilla PhysX always runs as fallback (vehicles, doors, non-block geometry).

using System.Collections.Generic;
using HarmonyLib;
using UnityEngine;

// ============================================================
// Patch 1: EntityMoveHelper.CheckWorldBlocked
//
// Vanilla does a full physics raycast from entity to moveToPos.
// Voxel fast-reject: if the voxel grid says "blocked", set the
// blocked flag and skip the physics sweep entirely.
// If voxel says "clear", fall through to vanilla for edge cases.
// ============================================================
[HarmonyPatch(typeof(EntityMoveHelper), nameof(EntityMoveHelper.CheckWorldBlocked))]
static class EMH_CheckWorldBlocked_VoxelReject
{
    static bool Prefix(EntityMoveHelper __instance,
        ref int ___BlockedFlags,
        WorldRayHitInfo ___HitInfo)
    {
        try
        {
            var start = __instance.entity.getHeadPosition();
            start.y = __instance.entity.position.y;
            var end = __instance.moveToPos;
            var dir = end - start;
            var dist = dir.magnitude;
            if (dist <= 0f) return true;

            var ray = new Ray(start, dir / dist);

            if (Voxel.GetNextBlockHit(__instance.entity.world, ray, dist,
                    EntityMoveHelper.cCollisionMask, false))
            {
                ___HitInfo.CopyFrom(Voxel.voxelRayHitInfo);
                ___BlockedFlags = 1;
                return false;
            }
        }
        catch { }

        return true;
    }
}

// ============================================================
// Patch 2: EntityMoveHelper.CheckBlocked
//
// Called in a tight loop from CheckAreaBlocked (height × 3 edges).
// Each call does a physics raycast. Voxel fast-reject catches the
// common case where a solid block is in the way.
// ============================================================
[HarmonyPatch(typeof(EntityMoveHelper), nameof(EntityMoveHelper.CheckBlocked))]
static class EMH_CheckBlocked_VoxelReject
{
    static bool Prefix(EntityMoveHelper __instance,
        Vector3 pos, Vector3 endPos, int baseY, bool checkSlope,
        WorldRayHitInfo hitInfo)
    {
        try
        {
            var dir = endPos - pos;
            var dist = dir.magnitude + 0.001f;
            if (dist <= 0f) return true;
            dir /= dist;

            var ray = new Ray(pos - dir * 0.375f, dir);

            if (Voxel.GetNextBlockHit(__instance.entity.world, ray, dist,
                    EntityMoveHelper.cCollisionMask, false))
            {
                hitInfo.CopyFrom(Voxel.voxelRayHitInfo);
                __instance.BlockedFlags |= 1 << baseY;
                return false;
            }
        }
        catch { }

        return true;
    }
}

// ============================================================
// Patch 3: EntityMoveHelper.CalcObstacleSideStepArc
//
// Vanilla does Physics.SphereCast per angle step × per height layer.
// This is the most expensive of the movement helper methods because
// it loops over angles AND heights.
//
// Voxel fast-reject: for each angle, do a single voxel ray at each
// height. If ANY height is blocked by voxel, return that angle
// immediately. If no voxel hit at any height, fall through to vanilla
// (catches non-block colliders like vehicles).
// ============================================================
[HarmonyPatch(typeof(EntityMoveHelper), nameof(EntityMoveHelper.CalcObstacleSideStepArc))]
static class EMH_CalcObstacleSideStepArc_VoxelReject
{
    static bool Prefix(EntityMoveHelper __instance,
        ref float __result,
        Vector3 startPos,
        float angleRad,
        float dirMin,
        float dirMax,
        float dirStep)
    {
        try
        {
            float baseRadius = __instance.ccRadius + 0.45f;
            float ccHeight = __instance.ccHeight;
            var world = __instance.entity.world;

            for (float a = dirMin; a <= dirMax; a += dirStep)
            {
                float rad = angleRad + a * Mathf.Deg2Rad;
                var dir = new Vector3(Mathf.Sin(rad), 0f, Mathf.Cos(rad));
                float maxDist = baseRadius / Mathf.Cos(a * Mathf.Deg2Rad);
                if (maxDist <= 0f) maxDist = baseRadius;

                // Check at multiple heights like vanilla does
                for (float h = ccHeight - 0.1f; h > 0.3f; h -= 0.9f)
                {
                    var origin = startPos;
                    origin.y += h;
                    var ray = new Ray(origin, dir);

                    if (Voxel.GetNextBlockHit(world, ray, maxDist,
                            EntityMoveHelper.cCollisionMask, false))
                    {
                        __result = a;
                        return false;
                    }
                }
            }
        }
        catch { }

        // No voxel hit — let vanilla physics sweep confirm
        return true;
    }
}

// ============================================================
// Patch 4: EntityMoveHelper.CheckEntityBlocked
//
// Vanilla does Physics.SphereCast to find nearby blocking entities.
// Replace with cheap spatial query + distance/dot-product math.
// This is a FULL REPLACEMENT (returns false always on success)
// because entity-entity blocking doesn't need PhysX at all.
// ============================================================
[HarmonyPatch(typeof(EntityMoveHelper), nameof(EntityMoveHelper.CheckEntityBlocked))]
static class EMH_CheckEntityBlocked_VoxelReject
{
    static readonly List<Entity> s_nearby = new List<Entity>(16);

    static bool Prefix(EntityMoveHelper __instance, Vector3 pos, Vector3 endPos)
    {
        try
        {
            var vector = endPos - pos;
            if (vector.sqrMagnitude < 0.0001f)
                return false;

            const float maxDist = 0.8f;

            __instance.entity.world.GetEntitiesAround(
                (EntityFlags)6, pos, maxDist, s_nearby);

            var dir = vector;
            dir.y = 0f;
            if (dir.sqrMagnitude > 0f) dir.Normalize();

            foreach (var e in s_nearby)
            {
                if (e == __instance.entity) continue;
                if (!(e is EntityAlive alive)) continue;

                var toEnt = alive.position - pos;
                toEnt.y = 0f;
                float d2 = toEnt.sqrMagnitude;
                if (d2 > maxDist * maxDist) continue;

                if (dir.sqrMagnitude > 0f &&
                    Vector3.Dot(dir, toEnt.normalized) < 0.5f) continue;

                float radius = __instance.ccRadius
                    + alive.m_characterController.GetRadius()
                    + 0.16f + 0.25f;

                if (d2 < radius * radius)
                {
                    __instance.BlockedEntity = alive;
                    __instance.blockedEntityDistSq = d2;
                    break;
                }
            }

            s_nearby.Clear();
            return false;
        }
        catch
        {
            s_nearby.Clear();
            return true;
        }
    }
}

// ============================================================
// Patch 5: ASPPathFinder.IsLineClear (path smoothing)
//
// Called during path post-processing. Vanilla does up to 4 PhysX
// calls per smoothing step: Linecast + SphereCast at two heights
// for tall entities.
//
// Voxel fast-reject: if a voxel ray says blocked, return false
// immediately (line is NOT clear). If voxel says clear, fall
// through to vanilla for non-block colliders.
// ============================================================
[HarmonyPatch(typeof(GamePath.ASPPathFinder), "IsLineClear")]
static class ASP_IsLineClear_VoxelReject
{
    static bool Prefix(GamePath.ASPPathFinder __instance,
        ref bool __result,
        Vector3 pos1, Vector3 pos2, bool isTall)
    {
        try
        {
            if (Mathf.Abs(pos1.y - pos2.y) > 0.5f)
            {
                __result = false;
                return false;
            }

            // Access the entity's world through the instance
            var entity = Traverse.Create(__instance).Field("entity").GetValue<EntityAlive>();
            if (entity?.world == null) return true;
            var world = entity.world;

            const int collisionMask = 1082195968;

            // Check at lower height (pos1.y + 0.5)
            var low1 = pos1;
            low1.y += 0.5f;
            var low2 = pos2;
            low2.y += 0.5f;
            var dir = low2 - low1;
            float dist = dir.magnitude;
            if (dist <= 0f) return true;

            var ray = new Ray(low1, dir / dist);
            if (Voxel.GetNextBlockHit(world, ray, dist, collisionMask, false))
            {
                __result = false;
                return false;
            }

            // Check at upper height for tall entities
            if (isTall)
            {
                low1.y += 1f;
                low2.y += 1f;
                dir = low2 - low1;
                ray = new Ray(low1, dir / dist);
                if (Voxel.GetNextBlockHit(world, ray, dist, collisionMask, false))
                {
                    __result = false;
                    return false;
                }
            }
        }
        catch { }

        // Voxel says clear — let vanilla physics confirm
        return true;
    }
}

// ============================================================
// Patch 6: EAIApproachAndAttackTarget.GetMoveToLocation
//
// Contains a single downward Physics.Raycast (1.02m) to find
// ground height at an approach position. Replace with a voxel
// block lookup for the common flat-ground case.
//
// If the block below is solid, use its top face Y as ground.
// If air/complex geometry, fall through to vanilla physics.
// ============================================================
[HarmonyPatch(typeof(EAIApproachAndAttackTarget), "GetMoveToLocation")]
static class EAI_GetMoveToLocation_VoxelGround
{
    static bool Prefix(EAIApproachAndAttackTarget __instance,
        ref Vector3 __result,
        float maxDist)
    {
        try
        {
            // Access private fields via Traverse
            var trav = Traverse.Create(__instance);
            var entityTarget = trav.Field("entityTarget").GetValue<EntityAlive>();
            var theEntity = trav.Field("theEntity").GetValue<EntityAlive>();
            var isTargetToEat = trav.Field("isTargetToEat").GetValue<bool>();
            var entityTargetVel = trav.Field("entityTargetVel").GetValue<Vector3>();

            if (entityTarget?.world == null || theEntity == null)
                return true;

            var pos = entityTarget.position;
            pos += entityTargetVel * 6f;
            if (isTargetToEat)
                pos = entityTarget.getBellyPosition();

            pos = entityTarget.world.FindSupportingBlockPos(pos);

            if (maxDist <= 0f)
            {
                __result = pos;
                return false;
            }

            var vector = new Vector3(theEntity.position.x, pos.y, theEntity.position.z);
            var vector2 = pos - vector;
            float magnitude = vector2.magnitude;

            if (magnitude >= 3f)
            {
                __result = pos;
                return false;
            }

            if (magnitude <= maxDist)
            {
                float yDiff = pos.y - theEntity.position.y;
                __result = (yDiff < -3f || yDiff > 1.5f) ? pos : vector;
                return false;
            }

            // This is the path that contains the Physics.Raycast
            vector2 *= maxDist / magnitude;
            var vector3 = pos - vector2;
            vector3.y += 0.51f;
            var pos2 = World.worldToBlockPos(vector3);
            var block = entityTarget.world.GetBlock(pos2);
            var block2 = block.Block;

            if (block2.PathType <= 0)
            {
                // Voxel ground check: look at the block directly below
                var belowPos = new Vector3i(pos2.x, pos2.y - 1, pos2.z);
                var belowBlock = entityTarget.world.GetBlock(belowPos);

                if (!belowBlock.isair && !belowBlock.Block.IsMovementBlocked(
                        entityTarget.world, belowPos, belowBlock, BlockFace.None))
                {
                    // Solid block below — use its top face as ground height
                    vector3.y = pos2.y;
                    __result = vector3;
                    return false;
                }

                // Check elevator case
                if (block2.IsElevator(block.rotation))
                {
                    vector3.y = pos.y;
                    __result = vector3;
                    return false;
                }

                // Complex geometry — fall through to vanilla Physics.Raycast
                return true;
            }

            __result = pos;
            return false;
        }
        catch { }

        return true;
    }
}
